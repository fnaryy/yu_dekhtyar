# SQLite database — contains seeded password hashes, leads with IPs, regenerable from migrations
/database/*.sqlite
/database/*.sqlite-journal

# Uploaded media (client photos, video thumbnails) — stored separately, not in source
/storage/app/public/*
!/storage/app/public/.gitkeep

# Laravel logs
/storage/logs/*.log

# Claude Code local settings — may cache command strings with secrets in URLs
/.claude/
